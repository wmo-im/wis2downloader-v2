LOG_LEVEL=DEBUG

SUBSCRIBER_CONFIG_PATH=/app/config/config.json
FLASK_SECRET_KEY="dev"

DATA_PATH=/data

CELERY_BROKER_URL="sentinel://redis-sentinel-1:26379;sentinel://redis-sentinel-2:26379;sentinel://redis-sentinel-3:26379/0"
CELERY_BROKER_TRANSPORT_OPTIONS={"master_name": "redis-primary"}

CELERY_RESULT_BACKEND="sentinel://redis-sentinel-1:26379;sentinel://redis-sentinel-2:26379;sentinel://redis-sentinel-3:26379/1"
CELERY_RESULT_BACKEND_TRANSPORT_OPTIONS={"master_name": "redis-primary"}

REDIS_SENTINEL_HOSTS="redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379"
REDIS_PRIMARY_NAME="redis-primary"
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_TTL_SECONDS=3600
REDIS_MESSAGE_LOCK=300

# comma seperated list of global caches to exclude
GC_EXCLUDE=wis2.ncm.gov.sa